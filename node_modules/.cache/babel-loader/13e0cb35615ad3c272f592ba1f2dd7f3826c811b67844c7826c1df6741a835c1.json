{"ast":null,"code":"import NewMessageForm from './NewMessageForm.vue';\nimport MessageList from './MessageList.vue';\nexport default {\n  components: {\n    NewMessageForm,\n    MessageList\n  },\n  data() {\n    return {\n      showNewMessage: false,\n      showMessageList: false\n    };\n  },\n  watch: {\n    showNewMessage(newValue) {\n      if (newValue) {\n        this.showMessageList = false;\n      }\n    },\n    showMessageList(newValue) {\n      if (newValue) {\n        this.showNewMessage = false;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AAgBA;AACA;AAEA;EACAA;IACAC;IACAC;EACA;EACAC;IACA;MACAC;MACAC;IACA;EACA;EACAC;IACAF;MACA;QACA;MACA;IACA;IACAC;MACA;QACA;MACA;IACA;EACA;AACA","names":["components","NewMessageForm","MessageList","data","showNewMessage","showMessageList","watch"],"sourceRoot":"src","sources":["App.vue"],"sourcesContent":["<template>\n  <div>\n    <button class=\"button\" @click=\"showNewMessage = true\">Neue Meldung</button>\n    <button class=\"button\" @click=\"showMessageList = true\">Zustand abfragen</button>\n\n    <div v-if=\"showNewMessage\">\n      <NewMessageForm />\n    </div>\n\n    <div v-if=\"showMessageList\">\n      <MessageList />\n    </div>\n  </div>\n</template>\n\n<script>\nimport NewMessageForm from './NewMessageForm.vue'\nimport MessageList from './MessageList.vue'\n\nexport default {\n  components: {\n    NewMessageForm,\n    MessageList\n  },\n  data() {\n    return {\n      showNewMessage: false,\n      showMessageList: false\n    }\n  },\n  watch: {\n    showNewMessage(newValue) {\n      if (newValue) {\n        this.showMessageList = false\n      }\n    },\n    showMessageList(newValue) {\n      if (newValue) {\n        this.showNewMessage = false\n      }\n    }\n  }\n}\n</script>\n\n<style>\n.button {\n  margin: 10px;\n  padding: 10px;\n  border: 1px solid #000000;\n  border-radius: 5px;\n\n  background-color: #2e6a9c;\n  cursor: pointer;\n  color: #ffffff;\n  box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.3);\n}\n\n.button:hover {\n    background-color: #3d7ebc;\n}\n\n.button:active {\n  background-color: #1e4a6c; /* Change the background color on click */\n  box-shadow: none; /* Remove the box shadow on click */\n}\n\n</style>"]},"metadata":{},"sourceType":"module","externalDependencies":[]}