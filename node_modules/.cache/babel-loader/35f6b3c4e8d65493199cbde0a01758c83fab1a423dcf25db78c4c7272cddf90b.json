{"ast":null,"code":"export default {\n  data() {\n    return {\n      items: [{\n        title: \"Meldung 5\",\n        content: \"Inhalt der Meldung 5\",\n        image: null,\n        status: \"Eingegangen\"\n      }, {\n        title: \"Meldung 6\",\n        content: \"Inhalt der Meldung 6\",\n        image: null,\n        status: \"Empfangen\"\n      }, {\n        title: \"Meldung 7\",\n        content: \"Inhalt der Meldung 7\",\n        image: null,\n        status: \"in Bearbeitung\"\n      }, {\n        title: \"Meldung 8\",\n        content: \"Inhalt der Meldung 8\",\n        image: null,\n        status: \"Abgeschlossen\"\n      }],\n      selectedItem: null,\n      statuses: [\"Eingegangen\", \"Empfangen\", \"in Bearbeitung\", \"Abgeschlossen\"]\n    };\n  },\n  methods: {\n    selectItem(index) {\n      this.selectedItem = index;\n    },\n    closeItem() {\n      this.selectedItem = null;\n    },\n    nextItem() {\n      if (this.selectedItem < this.items.length - 1) {\n        this.selectedItem++;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AA+CA;EACAA;IACA;MACAC,QACA;QAAAC;QAAAC;QAAAC;QAAAC;MAAA,GACA;QAAAH;QAAAC;QAAAC;QAAAC;MAAA,GACA;QAAAH;QAAAC;QAAAC;QAAAC;MAAA,GACA;QAAAH;QAAAC;QAAAC;QAAAC;MAAA,EACA;MACAC;MACAC;IACA;EACA;EACAC;IACAC;MACA;IACA;IACAC;MACA;IACA;IACAC;MACA;QACA;MACA;IACA;EACA;AACA","names":["data","items","title","content","image","status","selectedItem","statuses","methods","selectItem","closeItem","nextItem"],"sourceRoot":"src","sources":["MessageList.vue"],"sourcesContent":["<template>\n  <div id=\"app\" class=\"container\">\n    <!-- List of Items -->\n    <div class=\"items-list\">\n      <div \n        v-for=\"(item, index) in items\" \n        :key=\"item.id\" \n        class=\"item\" \n        :class=\"{ active: selectedItem === index }\"\n        @click=\"selectItem(index)\"\n      >\n        {{ item.title }}\n      </div>\n    </div>\n\n    <!-- Content Display and Status Bar -->\n    <div class=\"content-area\">\n      <div class=\"content-display\" v-if=\"selectedItem !== null\">\n        <h3>{{ items[selectedItem].title }}</h3>\n        <p>{{ items[selectedItem].content }}</p>\n        <img v-if=\"items[selectedItem].image\" :src=\"items[selectedItem].image\" alt=\"content image\" />\n      </div>\n\n      <!-- Status Indicators -->\n      <div class=\"status-bar-container\">\n        <div \n          v-for=\"(status, index) in statuses\" \n          :key=\"status\" \n          :class=\"[\n            'status-circle', \n            { \n              active: items[selectedItem]?.status === status,\n              'before-active': selectedItem !== null && index < statuses.indexOf(items[selectedItem].status)\n            }\n          ]\"\n        ></div>\n        <div \n          v-for=\"(status, index) in statuses.slice(0, -1)\" \n          :key=\"status + '-' + statuses[index + 1]\"\n          class=\"status-bar-line\"\n        ></div>\n      </div> \n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      items: [\n        { title: \"Meldung 5\", content: \"Inhalt der Meldung 5\", image: null, status: \"Eingegangen\" },\n        { title: \"Meldung 6\", content: \"Inhalt der Meldung 6\", image: null, status: \"Empfangen\" },\n        { title: \"Meldung 7\", content: \"Inhalt der Meldung 7\", image: null, status: \"in Bearbeitung\" },\n        { title: \"Meldung 8\", content: \"Inhalt der Meldung 8\", image: null, status: \"Abgeschlossen\" },\n      ],\n      selectedItem: null,\n      statuses: [\"Eingegangen\", \"Empfangen\", \"in Bearbeitung\", \"Abgeschlossen\"]\n    };\n  },\n  methods: {\n    selectItem(index) {\n      this.selectedItem = index;\n    },\n    closeItem() {\n      this.selectedItem = null;\n    },\n    nextItem() {\n      if (this.selectedItem < this.items.length - 1) {\n        this.selectedItem++;\n      }\n    },\n  },\n};\n</script>\n\n<style>\n.status-bar-container {\n  position: relative;\n}\n\n.status-bar-line {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  width: 2px;\n  height: 100%;\n  background-color: #ccc;\n}\n\n.status-circle {\n  position: relative;\n  display: inline-block;\n  width: 20px;\n  height: 20px;\n  border-radius: 50%;\n  margin-right: 10px;\n  background-color: #ccc;\n}\n\n.status-circle.active {\n  background-color: #007aff;\n}\n\n.status-circle.before-active::before {\n  content: '';\n  position: absolute;\n  top: 50%;\n  left: -10px;\n  transform: translateY(-50%);\n  width: 20px;\n  height: 2px;\n  background-color: #ccc;\n}\n\n.status-circle.active::before {\n  content: '';\n  position: absolute;\n  top: 50%;\n  left: -10px;\n  transform: translateY(-50%);\n  width: 20px;\n  height: 2px;\n  background-color: #007aff;\n}\n\n.status-circle.active::after {\n  content: '';\n  position: absolute;\n  top: 50%;\n  right: -10px;\n  transform: translateY(-50%);\n  width: 20px;\n  height: 2px;\n  background-color: #007aff;\n}\n</style>\n"]},"metadata":{},"sourceType":"module","externalDependencies":[]}