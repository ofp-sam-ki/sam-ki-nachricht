{"ast":null,"code":"export default {\n  data() {\n    return {\n      items: [{\n        title: \"Meldung 5\",\n        content: \"Inhalt der Meldung 5\",\n        image: null,\n        status: \"eingegangen\"\n      }, {\n        title: \"Meldung 6\",\n        content: \"Inhalt der Meldung 6\",\n        image: null,\n        status: \"in Bearbeitung\"\n      }, {\n        title: \"Meldung 7\",\n        content: \"Inhalt der Meldung 7\",\n        image: null,\n        status: \"abgeschlossen\"\n      }, {\n        title: \"Meldung 8\",\n        content: \"Inhalt der Meldung 8\",\n        image: null,\n        status: \"eingegangen\"\n      }],\n      selectedItem: null\n    };\n  },\n  methods: {\n    selectItem(index) {\n      this.selectedItem = index;\n    },\n    closeItem() {\n      this.selectedItem = null;\n    },\n    nextItem() {\n      if (this.selectedItem < this.items.length - 1) {\n        this.selectedItem++;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AA+BA;EACAA;IACA;MACAC,QACA;QAAAC;QAAAC;QAAAC;QAAAC;MAAA,GACA;QAAAH;QAAAC;QAAAC;QAAAC;MAAA,GACA;QAAAH;QAAAC;QAAAC;QAAAC;MAAA,GACA;QAAAH;QAAAC;QAAAC;QAAAC;MAAA,EACA;MACAC;IACA;EACA;EACAC;IACAC;MACA;IACA;IACAC;MACA;IACA;IACAC;MACA;QACA;MACA;IACA;EACA;AACA","names":["data","items","title","content","image","status","selectedItem","methods","selectItem","closeItem","nextItem"],"sourceRoot":"src","sources":["MessageList.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <!-- List of Items -->\n    <div class=\"items-list\">\n      <div class=\"item\" @click=\"selectItem(0)\">Meldung 5</div>\n      <div class=\"item\" @click=\"selectItem(1)\">Meldung 6</div>\n      <div class=\"item\" @click=\"selectItem(2)\">Meldung 7</div>\n      <div class=\"item\" @click=\"selectItem(3)\">Meldung 8</div>\n    </div>\n\n    <!-- Content Display -->\n    <div class=\"content-display\" v-if=\"selectedItem !== null\">\n      <h3>{{ items[selectedItem].title }}</h3>\n      <p>{{ items[selectedItem].content }}</p>\n      <img v-if=\"items[selectedItem].image\" :src=\"items[selectedItem].image\" alt=\"content image\" />\n    </div>\n\n    <!-- Status Indicators -->\n    <div class=\"status-indicators\">\n      <span class=\"status\">Zustand: {{ items[selectedItem].status }}</span>\n    </div>\n\n    <!-- Navigation Buttons -->\n    <div class=\"nav-buttons\">\n      <button @click=\"closeItem\">Schließen</button>\n      <button @click=\"nextItem\">Neäxt</button>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      items: [\n        { title: \"Meldung 5\", content: \"Inhalt der Meldung 5\", image: null, status: \"eingegangen\" },\n        { title: \"Meldung 6\", content: \"Inhalt der Meldung 6\", image: null, status: \"in Bearbeitung\" },\n        { title: \"Meldung 7\", content: \"Inhalt der Meldung 7\", image: null, status: \"abgeschlossen\" },\n        { title: \"Meldung 8\", content: \"Inhalt der Meldung 8\", image: null, status: \"eingegangen\" },\n      ],\n      selectedItem: null,\n    };\n  },\n  methods: {\n    selectItem(index) {\n      this.selectedItem = index;\n    },\n    closeItem() {\n      this.selectedItem = null;\n    },\n    nextItem() {\n      if (this.selectedItem < this.items.length - 1) {\n        this.selectedItem++;\n      }\n    },\n  },\n};\n</script>\n\n<style>\n.items-list .item {\n  cursor: pointer;\n  padding: 10px;\n  border: 1px solid #ccc;\n}\n.content-display {\n  padding: 20px;\n  border: 1px solid #ccc;\n  margin-top: 20px;\n}\n.status-indicators {\n  margin-top: 20px;\n}\n.nav-buttons {\n  margin-top: 20px;\n}\n</style>\n"]},"metadata":{},"sourceType":"module","externalDependencies":[]}